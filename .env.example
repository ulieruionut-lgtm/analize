# Configurare – OBLIGATORIU PostgreSQL
# Obține URL-ul din Railway: railway variables
# Sau din dashboard: proiect -> PostgreSQL -> Connect

DATABASE_URL=postgresql://user:parola@host:port/database
OCR_LANG=ron+eng
# Prag Tesseract (word confidence) pentru reconstrucție rânduri TSV; implicit 12 (mai permisiv pe scanuri slabe)
# OCR_WORD_CONF_FLOOR=12
PDF_TEXT_MIN_CHARS=200

# Autentificare (PRODUCȚIE: setează un secret puternic!)
# JWT_SECRET_KEY=un-string-lung-aleatoriu-secret

# --- AI Copilot (audit LLM la upload) — implicit oprit ---
# Pornești: LLM_BULETIN_AUDIT_ENABLED=true și cheie API.
#
# Varianta A — Claude Haiku (citire/analize rapide, API Anthropic):
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-api03-...
#   LLM_MODEL=claude-haiku-4-5-20251001
# (opțional: același rol cu LLM_API_KEY dacă pui cheia Anthropic acolo)
#
# Varianta B — OpenAI sau gateway compatibil:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=... sau OPENAI_API_KEY=...
#   DeepSeek exemplu: LLM_BASE_URL=https://api.deepseek.com LLM_MODEL=deepseek-chat
#
# LLM_BULETIN_AUDIT_ENABLED=false
# LLM_BULETIN_AUDIT_TIMEOUT_SECONDS=90
# LLM_PROVIDER=openai
# LLM_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
#
# Reîncărcare buletin (aceeași dată): completează analize mapate lipsă din încărcarea anterioară (implicit activ)
# PRIOR_UPLOAD_GAP_FILL_ENABLED=true
#
# După normalizare: învățare automată alias (LLM + catalog, peste prag salvează în DB). Implicit oprit.
# LLM_LEARN_FROM_UPLOAD_ENABLED=false
# LLM_LEARN_AUTO_APPLY_MIN_SCORE=86
# LLM_LEARN_MAX_CALLS_PER_UPLOAD=40
